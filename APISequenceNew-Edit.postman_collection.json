    {
      "name": "individualTotalExpensesR3",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "const data = response.individualTotalExpenses || [];\r",
              "\r",
              "// Status Code\r",
              "pm.test(\"Status Code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Response Time\r",
              "pm.test(\"Response Time is less than 2500ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2500);\r",
              "});\r",
              "\r",
              "// Content Type\r",
              "pm.test(\"Content Type is application/json\", () => {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// Response Body\r",
              "pm.test(\"Individual Total Expense response is an object\", () => {\r",
              "    pm.expect(response).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "if (!data.length) {\r",
              "    throw new Error(\"individualTotalExpenses not found in response\");\r",
              "}\r",
              "\r",
              "// Get supplement plan\r",
              "let supplementPlan = pm.variables.get(\"SupplimentPlan\");\r",
              "\r",
              "if (!supplementPlan) {\r",
              "    supplementPlan = pm.environment.get(\"SupplimentPlan\");\r",
              "}\r",
              "\r",
              "if (!supplementPlan) {\r",
              "    throw new Error(\"SupplimentPlan variable is not set\");\r",
              "}\r",
              "\r",
              "supplementPlan = String(supplementPlan).toLowerCase().trim();\r",
              "\r",
              "// Map plan to field\r",
              "const planFieldMap = {\r",
              "    plan_c: \"totalABCD\",\r",
              "    plan_d: \"totalABD\",\r",
              "    plan_f: \"totalABFD\",\r",
              "    plan_g: \"totalABGD\",\r",
              "    plan_n: \"totalABND\"\r",
              "};\r",
              "\r",
              "const totalField = planFieldMap[supplementPlan];\r",
              "\r",
              "if (!totalField) {\r",
              "    throw new Error(`Unsupported SupplimentPlan value: ${supplementPlan}`);\r",
              "}\r",
              "\r",
              "// Expense year range\r",
              "const fromYear = data[0].year;\r",
              "const toYear = data[data.length - 1].year;\r",
              "\r",
              "// Build expenses array\r",
              "const pv_expenses = data.map(item => ({\r",
              "    year: item.year,\r",
              "    expense: Math.round((item[totalField] || 0) + (item.partCOOP || 0))\r",
              "}));\r",
              "\r",
              "// Save variables used by expensesPresentValue\r",
              "pm.environment.set(\"pv_fromYear\", fromYear);\r",
              "pm.environment.set(\"pv_toYear\", toYear);\r",
              "pm.environment.set(\"pv_expenses\", JSON.stringify(pv_expenses));\r",
              "\r",
              "// Logs\r",
              "console.log(\"SupplimentPlan =\", supplementPlan);\r",
              "console.log(\"Using field =\", totalField);\r",
              "console.log(\"Using OOP field = partCOOP\");\r",
              "console.log(\"pv_fromYear =\", fromYear);\r",
              "console.log(\"pv_toYear =\", toYear);\r",
              "console.log(\"Generated pv_expenses =\", pv_expenses);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const birthDateRaw = pm.environment.get(\"fp_birthDate\");              // example: 09-1975\r",
              "const retirementYearRaw = pm.environment.get(\"fp_retirementYear\");    // example: 2040\r",
              "const lifeExpectancyRaw = pm.environment.get(\"edit_lifeExpectancy\");  // example: 91\r",
              "\r",
              "if (!birthDateRaw) {\r",
              "    throw new Error(\"fp_birthDate is missing\");\r",
              "}\r",
              "\r",
              "if (!retirementYearRaw) {\r",
              "    throw new Error(\"fp_retirementYear is missing\");\r",
              "}\r",
              "\r",
              "if (!lifeExpectancyRaw) {\r",
              "    throw new Error(\"edit_lifeExpectancy is missing\");\r",
              "}\r",
              "\r",
              "const birthParts = String(birthDateRaw).split(\"-\");\r",
              "if (birthParts.length < 2) {\r",
              "    throw new Error(`Invalid fp_birthDate format: ${birthDateRaw}`);\r",
              "}\r",
              "\r",
              "const birthYear = parseInt(birthParts[1], 10);\r",
              "const retirementYear = parseInt(retirementYearRaw, 10);\r",
              "const lifeExpectancy = parseInt(lifeExpectancyRaw, 10);\r",
              "\r",
              "if (Number.isNaN(birthYear)) {\r",
              "    throw new Error(`Invalid birth year: ${birthDateRaw}`);\r",
              "}\r",
              "\r",
              "if (Number.isNaN(retirementYear)) {\r",
              "    throw new Error(`Invalid fp_retirementYear: ${retirementYearRaw}`);\r",
              "}\r",
              "\r",
              "if (Number.isNaN(lifeExpectancy)) {\r",
              "    throw new Error(`Invalid edit_lifeExpectancy: ${lifeExpectancyRaw}`);\r",
              "}\r",
              "\r",
              "// Start from retirement year\r",
              "const startYear = retirementYear;\r",
              "\r",
              "// End at birth year + life expectancy\r",
              "const endYear = birthYear + lifeExpectancy;\r",
              "\r",
              "if (endYear < startYear) {\r",
              "    throw new Error(`Invalid year range. startYear=${startYear}, endYear=${endYear}`);\r",
              "}\r",
              "\r",
              "let magiList = [];\r",
              "\r",
              "for (let year = startYear; year <= endYear; year++) {\r",
              "    magiList.push({\r",
              "        magiTier: 1,\r",
              "        magiDollarAmount: null,\r",
              "        taxFilingStatus: null,\r",
              "        year: year\r",
              "    });\r",
              "}\r",
              "\r",
              "pm.environment.set(\"editYearWiseMagi\", JSON.stringify(magiList));\r",
              "\r",
              "console.log(\"birthYear =\", birthYear);\r",
              "console.log(\"retirementYear =\", retirementYear);\r",
              "console.log(\"lifeExpectancy =\", lifeExpectancy);\r",
              "console.log(\"startYear =\", startYear);\r",
              "console.log(\"endYear =\", endYear);\r",
              "console.log(\"editYearWiseMagi =\", pm.environment.get(\"editYearWiseMagi\"));\r",
              "\r",
              "\r",
              "pm.environment.set(\"selectedPlan\", \"ABCD\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
